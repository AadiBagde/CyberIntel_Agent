# Application
APP_NAME=CyberIntel Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://cyberintel:cyberintel@localhost:5432/cyberintel

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=investigations

# LLM (Phase 2+)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Threat intelligence (Phase 1)
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=1

# Observability (Phase 9+)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
